  "<h3 style=\"color:#0B3D2E; margin: 24px 0 12px; font-size:16px;\">📖 التلاوات (Recitations)</h3>\n            <table style=\"width:100%; border-collapse: collapse; background:#fff; border:1px solid #e2e8f0; border-radius:10px; overflow:hidden;\">",
