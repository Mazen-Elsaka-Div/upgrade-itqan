  "<h3 style=\"color:#0B3D2E; margin: 24px 0 12px; font-size:16px;\">🏅 الشارات الجديدة</h3>\n             <ul style=\"padding-right:18px; margin: 0;\">",
  "\" style=\"display:inline-block; background:#0B3D2E; color:white; text-decoration:none; padding:12px 28px; border-radius:10px; font-weight:bold;\">\n                عرض التقرير الكامل في المنصة\n              </a>\n            </div>",
  "<hr style=\"border:none; border-top:1px solid #e2e8f0; margin: 24px 0;\" />\n      <p style=\"font-size: 12px; color:#94a3b8; text-align:center;\">\n        منصة إتقان التعليمية — جميع الحقوق محفوظة\n      </p>\n    </div>",
  "تقرير",
